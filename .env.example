# Local developer config for the test suite. Copy to `.env` (gitignored) and fill in.
# Non-secret settings only.

# Local Ollama model
OLLAMA_API_BASE=http://127.0.0.1:11434
EVALDATA_LOCAL_MODEL=ollama_chat/qwen2.5-coder:1.5b

# Hosted model
EVALDATA_HOSTED_MODEL=anthropic/claude-haiku-4-5

# Databricks SQL warehouse
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
